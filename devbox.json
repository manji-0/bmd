{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.2/.schema/devbox.schema.json",
  "packages": [
    "rustup@latest",
    "clang@latest",
    "libiconv@latest",
    "prek@latest",
    "sccache@latest",
    "zig@0.14.1"
  ],
  "env": {
    "RUSTUP_HOME":   "$PWD/.rustup",
    "CARGO_HOME":    "$PWD/.cargo",
    "SCCACHE_DIR":   "$PWD/.sccache",
    "RUSTFLAGS":     "-C linker=clang",
    "RUSTC_WRAPPER": "sccache"
  },
  "shell": {
    "init_hook": [
      "mkdir -p \"$RUSTUP_HOME\" \"$CARGO_HOME\" \"$SCCACHE_DIR\""
    ],
    "scripts": {
      "setup": [
        "rustup toolchain install",
        "rustup target add x86_64-unknown-linux-musl aarch64-unknown-linux-musl",
        "cargo fetch",
        "cargo install cargo-zigbuild --locked"
      ],
      "build": "cargo build",
      "build-release": "cargo build --release",
      "build-linux-x86_64": "RUSTFLAGS= RUSTC_WRAPPER= cargo zigbuild --release --locked --target x86_64-unknown-linux-musl",
      "build-linux-aarch64": "RUSTFLAGS= RUSTC_WRAPPER= cargo zigbuild --release --locked --target aarch64-unknown-linux-musl",
      "package": [
        "mkdir -p dist",
        "cargo build --release --locked",
        "tar czf dist/bmd-$(rustc -vV | sed -n 's/^host: //p').tar.gz -C target/release bmd",
        "RUSTFLAGS= RUSTC_WRAPPER= cargo zigbuild --release --locked --target x86_64-unknown-linux-musl",
        "tar czf dist/bmd-x86_64-unknown-linux-musl.tar.gz -C target/x86_64-unknown-linux-musl/release bmd",
        "RUSTFLAGS= RUSTC_WRAPPER= cargo zigbuild --release --locked --target aarch64-unknown-linux-musl",
        "tar czf dist/bmd-aarch64-unknown-linux-musl.tar.gz -C target/aarch64-unknown-linux-musl/release bmd",
        "cargo package --locked --no-verify"
      ],
      "test":        "cargo test -- --show-output",
      "run":         "cargo run --",
      "clippy":      "cargo clippy --all-targets -- -D warnings",
      "fmt":         "cargo fmt --all",
      "fmt-check":   "cargo fmt --all -- --check",
      "prek":        "prek run --all-files",
      "cache-stats": "sccache --show-stats"
    }
  }
}
